# Copy this file to `.env` (same folder) and fill in real values.
# `.env` itself is gitignored — never commit real secrets.

# Must match SECURECITY_ENGINE_KEY in backend/.env exactly — this is what
# authenticates ai_engine's POSTs to the backend's /api/v1/engine/* routes.
SECURECITY_ENGINE_KEY=

# Where the backend is reachable from this machine.
SECURECITY_BACKEND_URL=http://localhost:8000

# Video source: "0" = default webcam, a video file path, or an rtsp:// URL.
# NOTE: leaving this on "0" opens your real webcam the moment the pipeline
# starts — use a video file path (or "none") while developing if you don't
# want that. --source on the CLI overrides this.
SECURECITY_SOURCE=none

# Must match an existing camera's `code` in the backend (e.g. seeded
# "CAM-01") — name/lat/lng/zone/status are fetched live from there.
# --camera on the CLI overrides this.
SECURECITY_CAMERA_CODE=CAM-01
