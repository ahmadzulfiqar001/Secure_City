# Copy this file to `.env` (same folder) and fill in real values.
# `.env` itself is gitignored — never commit real secrets.
# Every setting maps to a field on Settings in app/core/config.py
# (SettingsConfigDict env_prefix="SECURECITY_").

# ── Core ──────────────────────────────────────────────────────────────
SECURECITY_ENVIRONMENT=development
SECURECITY_DEBUG=true
SECURECITY_LOG_LEVEL=INFO

# SQLite by default (per A2 — swappable to Postgres later without touching
# any route, only app/core/db.py + the repository layer).
SECURECITY_DATABASE_URL=sqlite:///./securecity.db

# ── Auth (rebuilt properly by the Auth module) ──────────────────────
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECURECITY_JWT_SECRET=

# ── AI engine bridge (rebuilt by the Camera/Detections module) ─────
# Must match SECURECITY_ENGINE_KEY in ai_engine/.env exactly.
# Generate one with: python -c "import secrets; print(secrets.token_hex(24))"
SECURECITY_ENGINE_KEY=

# ── Groq (reserved — not wired into any feature yet) ────────────────
# Get a free key at https://console.groq.com/keys
# Groq is an LLM (chat) API, not a data source — it can't fetch real
# weather/traffic/etc, only generate text from data we already have.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Map (no key needed) ──────────────────────────────────────────────
# The Flutter app's map uses flutter_map with free OpenStreetMap/CartoDB
# tiles and free Nominatim search — no API key required. Only relevant if
# you specifically want literal Google Maps tiles/branding instead, which
# needs a Google Cloud project with billing enabled:
# GOOGLE_MAPS_API_KEY=

# ── Push notifications (optional) ───────────────────────────────────
# True push (alerts reaching a closed/backgrounded app) needs Firebase
# Cloud Messaging. Local (in-app) notifications work today with zero keys.
# FIREBASE_PROJECT_ID=
# FIREBASE_SERVER_KEY=
