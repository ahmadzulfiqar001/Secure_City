# Copy this file to `.env` (same folder) and fill in real values.
# `.env` itself is gitignored — never commit real secrets.

# ── Auth (required for real security) ──────────────────────────────
# Signs/verifies the JWTs issued by /api/auth/login and /api/auth/register.
# Falls back to an insecure dev-only default if unset — MUST be set to a
# long random string before this is ever exposed outside your own machine.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECURECITY_JWT_SECRET=

# ── Detection engine ────────────────────────────────────────────────
# Video source for the YOLOv8 detection loop: "0" = default webcam, or a
# path to a video file. Defaults to "0" if unset.
# NOTE: leaving this on "0" means the backend opens your real webcam the
# moment it starts — set it to a video file path (or a harmless value like
# "none") while developing if you don't want that.
SECURECITY_SOURCE=0

# ── Groq (reserved — not wired into any feature yet) ────────────────
# Get a free key at https://console.groq.com/keys
# Groq is an LLM (chat) API, not a data source — it can't fetch real
# weather/traffic/etc, only generate text from data we already have. Nothing
# reads this yet; it's here so whichever feature ends up using an LLM (e.g.
# an AI-written risk summary) has somewhere to get the key from.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Map (no key needed) ──────────────────────────────────────────────
# The Flutter app's map uses flutter_map with free OpenStreetMap/CartoDB
# tiles and free Nominatim search — no API key required, and it already
# covers all of Pakistan (and the whole world). This section only matters
# if you specifically want literal Google Maps tiles/branding instead, which
# needs a Google Cloud project with billing enabled:
# GOOGLE_MAPS_API_KEY=
